# ── Backend secrets (set as Render environment variables; never commit .env) ─────

# LLM — Primary + Vision/OCR (Google AI Studio)
GEMINI_API_KEY=REPLACE_ME

# Speech STT + TTS (Telugu/Hindi, Sarvam AI)
SARVAM_API_KEY=REPLACE_ME

# Supabase (Postgres + pgvector)
SUPABASE_URL=https://REPLACE_ME.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi-REPLACE_ME

# Supabase anon key — used ONLY in GitHub Actions keep-alive ping
SUPABASE_ANON_KEY=eyJhbGciOi-REPLACE_ME

# Web Push VAPID keys — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=REPLACE_ME
VAPID_PRIVATE_KEY=REPLACE_ME

# ── Frontend env vars (Cloudflare Pages build settings) ─────────────────────────
# Only these two go to the client. Never add secrets below this line.
VITE_API_BASE_URL=https://navyasathi-api.onrender.com
VITE_VAPID_PUBLIC_KEY=REPLACE_ME
